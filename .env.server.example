APP_NAME=SpotOnApp
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://www.spotonapp.cloud

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=spotonapp_db
DB_USERNAME=spotonapp_user
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.spotonapp.cloud

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
SPOTON_AUDIO_DISK=public
SPOTON_AUDIO_DIRECTORY=post-audios
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@spotonapp.cloud
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@spotonapp.cloud"
MAIL_FROM_NAME="${APP_NAME}"

SPOTON_EMAIL_VERIFICATION_EXPIRE_MINUTES=60
SPOTON_PASSWORD_RESET_EXPIRE_MINUTES=30
SPOTON_PASSWORD_RESET_URL=https://www.spotonapp.cloud/reset-password
SPOTON_EMAIL_VERIFIED_URL=https://www.spotonapp.cloud/email-verified

PUSH_DRIVER=log
EXPO_PUSH_ENDPOINT=https://exp.host/--/api/v2/push/send
EXPO_PUSH_RECEIPTS_ENDPOINT=https://exp.host/--/api/v2/push/getReceipts
EXPO_ACCESS_TOKEN=

VITE_APP_NAME="${APP_NAME}"
